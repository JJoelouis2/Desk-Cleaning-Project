#define FaceDownIR A2
#define FaceForwardIR A5

#include <AFMotor.h>

AF_DCMotor motor1(1);  // front left
AF_DCMotor motor2(2);
AF_DCMotor motor3(3);
AF_DCMotor motor4(4);  // front right

int motor1Speed = 120;
int motor2Speed = 120;
int motor3Speed = 120;
int motor4Speed = 120;

float motor1AdjustmentFactor = 1.1;
float motor2AdjustmentFactor = 1.1;
float motor3AdjustmentFactor = 1.7;
float motor4AdjustmentFactor = 1.3;

float floorGripFactor = 0.9;

// PER LOOP VARS =============================================================================================
bool done = false;

bool debounce = false;
bool objectInFrontVar = false;
bool surfaceBelowVar = true;

bool FaceDownIRState = HIGH;
bool FaceForwardIRState = HIGH;

unsigned long lastCheckedIntersect = 0;

// PATH RELATED STUFF (e.g. position , already traveled, orientation) ==================================================================

struct Region {
  int x1, y1;
  int x2, y2;
};

int maxRegionCount = 12;

Region regions[12 ];
int regionCount = 0;

bool alignedx = true;
bool positiveDir = true;

int currentX = 0;
int currentY = 0;

unsigned long beganForward;  // so the robot knows how long it has been traveling forward

// FUNCTIONS ===============================================================================================================

/**
 * @brief Allows robot to turn any degree and gives option to move back a bit to account for turn radius.
 * 
 * @param deg The amount of degrees to turn.
 * @param moveBack Whether to move back or not.
 * @return void
 */

void turn(float deg, bool moveBack) {
  int timeToTurnPerp = 825;  //test values until callibrated good enough (in ms)
  motor1.run(RELEASE);
  motor2.run(RELEASE);
  motor3.run(RELEASE);
  motor4.run(RELEASE);

  delay(350);

  if (moveBack) {
    motor1.setSpeed(120 * motor1AdjustmentFactor);
    motor2.setSpeed(120 * motor2AdjustmentFactor);
    motor3.setSpeed(120 * motor3AdjustmentFactor);
    motor4.setSpeed(120 * motor4AdjustmentFactor);
    motor1.run(BACKWARD);
    motor2.run(BACKWARD);
    motor3.run(BACKWARD);
    motor4.run(BACKWARD);
    delay(350);
  }

  motor1.run(RELEASE);
  motor2.run(RELEASE);
  motor3.run(RELEASE);
  motor4.run(RELEASE);

  motor1.setSpeed(110 * motor1AdjustmentFactor);
  motor2.setSpeed(110 * motor2AdjustmentFactor);

  motor3.setSpeed(110 * motor3AdjustmentFactor);
  motor4.setSpeed(110 * motor4AdjustmentFactor);

  if (deg > 0) {
    motor1.run(FORWARD);
    motor2.run(FORWARD);

    motor3.run(BACKWARD);
    motor4.run(BACKWARD);

    if (alignedx) {
      positiveDir = !positiveDir;
    }
  }

  else {
    motor1.run(BACKWARD);
    motor2.run(BACKWARD);

    motor3.run(FORWARD);
    motor4.run(FORWARD);

    if (!alignedx) {
      positiveDir = !positiveDir;
    }
  }

  float timeToDelay = (abs(deg) / 90.0) * timeToTurnPerp * floorGripFactor;

  delay(timeToDelay);
  motor4.run(RELEASE);
  motor3.run(RELEASE);
  motor2.run(RELEASE);
  motor1.run(RELEASE);

  motor4.setSpeed(motor4Speed * motor4AdjustmentFactor);
  motor3.setSpeed(motor3Speed * motor3AdjustmentFactor);
  motor2.setSpeed(motor2Speed * motor2AdjustmentFactor);
  motor1.setSpeed(motor1Speed * motor1AdjustmentFactor);

  alignedx = !alignedx;
}

bool isObjectInFront() {
  FaceForwardIRState = digitalRead(FaceForwardIR);

  if (FaceForwardIRState == LOW) {
    return true;
  }

  return false;
}

void addRegion(int x1, int y1, int x2, int y2) {
  if (regionCount < maxRegionCount) {
    regions[regionCount] = { x1, y1, x2, y2 };
    regionCount++;
  }
}

bool isSurfaceBeneath() {
  FaceDownIRState = digitalRead(FaceDownIR);

  if (FaceDownIRState == LOW) {
    return true;
  }

  return false;
}

// keeps track of where the robot is. Log position before turning since it uses positiveDIr and alignedx variables
// 100 ms is 1 unit forward
void logPosition() {
  int dirFlip;
  unsigned long currentTime = millis();

  unsigned long travelTime = currentTime - beganForward;

  if (positiveDir) {
    dirFlip = 1;
  }

  else {
    dirFlip = -1;
  }

  int unitsMoved = travelTime / 100;

  int startX = regions[regionCount-1].x2;
  int startY = regions[regionCount-1].y2;

  int endX;
  int endY;

  if (alignedx) {
    endX = startX + unitsMoved * dirFlip;
    endY = startY;
  }

  else {
    endX = startX;
    endY = startY + unitsMoved * dirFlip;
  }

  addRegion(startX, startY, endX, endY);
}

bool intersectWithExistingLine() {
  int dirFlip;
  float intersectDistance = 4.5; // intersectDistance/10 seconds of travel time away from line is considered intersecting

  if (positiveDir) {
    dirFlip = 1;
  }

  else {
    dirFlip = -1;
  }

  for (int i = 0; i < regionCount; i++) {
    if (alignedx) {
      if (regions[i].x1 == regions[i].x2) {               // ensures this is a vertical line
        int dist = (regions[i].x1 - currentX) * dirFlip;  // distance to line

        int minY = min(regions[i].y1, regions[i].y2);
        int maxY = max(regions[i].y1, regions[i].y2);

        if (dist > 0 && dist < intersectDistance && currentY >= minY && currentY <= maxY) {  // distance and that line exists directly in front of bot
          return true;
        }
      }
    }

    else {
      if (regions[i].y1 == regions[i].y2) {
        int dist = (regions[i].y1 - currentY) * dirFlip;

        int minX = min(regions[i].x1, regions[i].x2);
        int maxX = max(regions[i].x1, regions[i].x2);  // idk how necessary this is since the bot should travel in an enclosed shape but I've implemented it for now

        if (dist > 0 && dist < intersectDistance && currentX >= minX && currentX <= maxX) {  // distance and that line exists directly in front of bot
          return true;
        }
      }
    }
  }

  return false;
}

void forward() {
  motor4.setSpeed(motor4Speed * motor4AdjustmentFactor);
  motor3.setSpeed(motor3Speed * motor3AdjustmentFactor);
  motor2.setSpeed(motor2Speed * motor2AdjustmentFactor);
  motor1.setSpeed(motor1Speed * motor1AdjustmentFactor);

  motor4.run(FORWARD);
  motor3.run(FORWARD);
  motor2.run(FORWARD);
  motor1.run(FORWARD);
}

void releaseAll() {
  motor4.run(RELEASE);
  motor3.run(RELEASE);
  motor2.run(RELEASE);
  motor1.run(RELEASE);
}

// SETUP AND LOOP ==============================================

void setup() {
  pinMode(FaceDownIR, INPUT);
  pinMode(FaceForwardIR, INPUT);

  motor1.setSpeed(motor1Speed);
  motor1.run(RELEASE);

  motor2.setSpeed(motor2Speed);
  motor2.run(RELEASE);

  motor3.setSpeed(motor3Speed);
  motor3.run(RELEASE);

  motor4.setSpeed(motor4Speed);
  motor4.run(RELEASE);

  regions[0] = { 0, 0, 0, 0 };
  regionCount = 1;

  Serial.begin(9600);
  delay(1000);
}

void loop() {
  if (!done) {
    if (!debounce) {
      delay(8000);
      debounce = true;
      Serial.println("Loop First Run");
      forward();
      beganForward = millis();
    }

    objectInFrontVar = isObjectInFront();
    surfaceBelowVar = isSurfaceBeneath();

    if (regionCount >= maxRegionCount) {
      Serial.println("REGION EXCEEDED");
      done = true;
      releaseAll();
    }

    else if (!surfaceBelowVar) {
      releaseAll();
      logPosition();
      turn(-90, true);
      delay(500);
      forward();
      beganForward = millis();
    }

    else if (objectInFrontVar) {
      releaseAll();
      logPosition();
      turn(-90, true);
      delay(500);
      forward();
      beganForward = millis();
    }

    else {
      unsigned long currentTime = millis();
      if (currentTime - lastCheckedIntersect >= 100) {
        lastCheckedIntersect = currentTime;
        
        int dirFlip;
        unsigned long travelTime = currentTime - beganForward;

        if (positiveDir) {
          dirFlip = 1;
        }

        else {
          dirFlip = -1;
        }

        int unitsMoved = travelTime / 100;

        int startX = regions[regionCount-1].x2;
        int startY = regions[regionCount-1].y2;

        if (alignedx) {
          currentX = startX + unitsMoved * dirFlip;
          currentY = startY;
        }

        else {
          currentX = startX;
          currentY = startY + unitsMoved * dirFlip;
        }

        if (intersectWithExistingLine()) {
          releaseAll();
          logPosition();
          turn(-90, true);
          delay(500);
          forward();
          beganForward = millis();
        }
      }
    }
  }

  else {
    Serial.println("Regions:");
    for (int i = 0; i < regionCount; i++) {
      Serial.println("Region ");
      Serial.println(i);  
      Serial.println(regions[i].x1);
      Serial.println(",");
      Serial.println(regions[i].y1);
      Serial.println(",");
      Serial.println(regions[i].x2);
      Serial.println(",");
      Serial.println(regions[i].y2); 
    }
    delay(10000);
  }
}
