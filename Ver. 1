#define FaceDownIR A2
#define FaceForwardIR A5

#include <AFMotor.h>

AF_DCMotor motor1(1);  // front left
AF_DCMotor motor2(2);
AF_DCMotor motor3(3);
AF_DCMotor motor4(4);  // front right

int motor1Speed = 120;
int motor2Speed = 120;
int motor3Speed = 120;
int motor4Speed = 120;

float motor1AdjustmentFactor = 1;
float motor2AdjustmentFactor = 1;
float motor3AdjustmentFactor = 1.2;
float motor4AdjustmentFactor = 1.2;

bool debounce = true;
bool objectInFrontVar = false;

bool FaceDownIRState = HIGH;
bool FaceForwardIRState = HIGH;

void setup() {
  pinMode(FaceDownIR, INPUT);
  pinMode(FaceForwardIR, INPUT);

  motor1.setSpeed(motor1Speed);
  motor1.run(RELEASE);

  motor2.setSpeed(motor2Speed);
  motor2.run(RELEASE);

  motor3.setSpeed(motor3Speed);
  motor3.run(RELEASE);

  motor4.setSpeed(motor4Speed);
  motor4.run(RELEASE);

  Serial.begin(9600);
  delay(1000);
}

void turn(float deg, bool moveBack) {
  int timeToTurnPerp = 720;  //test values until callibrated good enough (in ms)
  if (moveBack) {
    motor1.setSpeed(120 * motor1AdjustmentFactor);
    motor2.setSpeed(120 * motor2AdjustmentFactor);
    motor3.setSpeed(120 * motor3AdjustmentFactor);
    motor4.setSpeed(120 * motor4AdjustmentFactor);
    motor1.run(BACKWARD);
    motor2.run(BACKWARD);
    motor3.run(BACKWARD);
    motor4.run(BACKWARD);
    delay(200);
  }

  motor1.run(RELEASE);
  motor2.run(RELEASE);
  motor3.run(RELEASE);
  motor4.run(RELEASE);

  motor1.setSpeed(120 * motor1AdjustmentFactor);
  motor2.setSpeed(120 * motor2AdjustmentFactor);

  motor3.setSpeed(120 * motor4AdjustmentFactor);
  motor4.setSpeed(120 * motor4AdjustmentFactor);

  if (deg > 0) {
    motor1.run(FORWARD);
    motor2.run(FORWARD);

    motor4.run(BACKWARD);
    motor4.run(BACKWARD);
  }

  else {
    motor1.run(BACKWARD);
    motor2.run(BACKWARD);

    motor4.run(FORWARD);
    motor4.run(FORWARD);
  }

  float timeToDelay = deg / 90 * timeToTurnPerp;

  delay(timeToDelay);
  motor4.run(RELEASE);
  motor3.run(RELEASE);
  motor2.run(RELEASE);
  motor1.run(RELEASE);

  motor4.setSpeed(motor4Speed * motor4AdjustmentFactor);
  motor3.setSpeed(motor3Speed * motor3AdjustmentFactor);
  motor2.setSpeed(motor2Speed * motor2AdjustmentFactor);
  motor1.setSpeed(motor1Speed * motor1AdjustmentFactor);
}

bool isObjectInFront() {
  FaceDownIRState = digitalRead(FaceDownIR);
  FaceForwardIRState = digitalRead(FaceForwardIR);

  if (FaceDownIRState == HIGH or FaceForwardIRState == LOW) {
    return true;
  }

  return false;
}

void forward() {
    motor4.setSpeed(motor4Speed * motor4AdjustmentFactor);
    motor3.setSpeed(motor4Speed * motor3AdjustmentFactor);
    motor2.setSpeed(motor4Speed * motor2AdjustmentFactor);
    motor1.setSpeed(motor4Speed * motor1AdjustmentFactor);

    motor4.run(FORWARD);
    motor3.run(FORWARD);
    motor2.run(FORWARD);
    motor1.run(FORWARD);
}

void loop() {
  if (debounce) {
    delay(8000);
    debounce = false;
    Serial.println("Loop First Run");
    forward();
  }

  objectInFrontVar = isObjectInFront();

  if (objectInFrontVar) {
    Serial.println("TURN!!!!");
    turn(90, true);

    delay(2000);
    forward();
  }
}
